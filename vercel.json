{
  "version": 2,
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/server.js"
    },
    {
      "src": "/analytics",
      "dest": "/public/analytics.html"
    },
    {
      "src": "/analytics.html",
      "dest": "/public/analytics.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}