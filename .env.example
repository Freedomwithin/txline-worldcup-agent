# Network
NETWORK=devnet

# Solana RPC
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_WS_RPC=wss://api.devnet.solana.com

# TxLINE API
TXLINE_API_TOKEN=your_api_token_here
